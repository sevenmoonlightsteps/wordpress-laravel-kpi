# WordPress KPI Plugin Configuration

# Laravel API Integration
# URL where the Laravel API is accessible (from WordPress container perspective)
LARAVEL_API_URL=http://laravel:9000

# Sanctum API token for authenticating requests to Laravel API
# Generate this in Laravel using: php artisan tinker
# \Laravel\Sanctum\PersonalAccessToken::createToken('wordpress-kpi-plugin', ['*']);
LARAVEL_API_TOKEN=your-laravel-sanctum-token-here

# WordPress Environment
# Values: local, development, staging, production
WP_ENVIRONMENT_TYPE=local

# Cache settings (optional, if using object cache)
# CACHE_DRIVER=redis
# REDIS_HOST=redis
# REDIS_PORT=6379
